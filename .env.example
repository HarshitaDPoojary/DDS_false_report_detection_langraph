# ── Elasticsearch ────────────────────────────────────────────────────────────
ES_HOST=http://localhost:9200
ES_API_KEY=
ES_INDEX=incident_reports

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=incident_reports

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4.1-mini
OPENAI_VISION_MODEL=gpt-4o

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SOC_SALT=
API_KEY=

# ── LangSmith (evaluation + tracing) ─────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__your_key_here
LANGCHAIN_PROJECT=false-report-identification

# ── vLLM (self-hosted OpenAI-compatible inference) ───────────────────────────
# Point at your local vLLM server. Leave VLLM_BASE_URL empty to skip local vLLM.
VLLM_BASE_URL=http://localhost:8000/v1
# Any non-empty string is accepted by vLLM as the API key
VLLM_API_KEY=your-vllm-token-here
# Model loaded on your vLLM server (must support vision + chat)
VLLM_VISION_MODEL=Qwen/Qwen2-VL-7B-Instruct

# ── NVIDIA NIM fallback ───────────────────────────────────────────────────────
# Used automatically when local vLLM is unreachable. Leave NIM_API_KEY empty to disable.
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_API_KEY=
NIM_VISION_MODEL=nvidia/llama-3.2-90b-vision-instruct

# ── Face Recognition ──────────────────────────────────────────────────────────
# Set FACE_RECOGNITION_ENABLED=true to enable InsightFace matching against known-offender DB.
# Requires: pip install insightface onnxruntime opencv-python-headless
FACE_RECOGNITION_ENABLED=false
# Path to known_offenders.json — format: [{offender_id, name, embedding: [512 floats]}]
KNOWN_OFFENDER_DB_PATH=
# Cosine similarity threshold for a positive face match (0.0–1.0)
FACE_MATCH_THRESHOLD=0.60
